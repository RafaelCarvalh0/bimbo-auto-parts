<div class="modal fade" id="createCategoryModal" tabindex="-1" aria-labelledby="createModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title" id="createModalLabel">
                    <i class="fas fa-plus-circle me-2" style="color:#2563eb;"></i>New Category
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Name <span style="color:#e11d48;">*</span></label>
                    <input type="text" id="inputName" class="form-control" placeholder="e.g. Electronics" maxlength="100" />
                    <div class="char-counter"><span id="nameCount">0</span>/100</div>
                    <div class="invalid-feedback" id="nameError"></div>
                </div>
                <div class="mb-1">
                    <label class="form-label">Description</label>
                    <textarea id="inputDescription" class="form-control" rows="3"
                              placeholder="Brief description of this category..." maxlength="500"></textarea>
                    <div class="char-counter"><span id="descCount">0</span>/500</div>
                    <div class="invalid-feedback" id="descError"></div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-cancel" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn-save" id="btnSave" onclick="CreateCategory()">
                    <i class="fas fa-check"></i> Save Category
                </button>
            </div>

        </div>
    </div>
</div>
